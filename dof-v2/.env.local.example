# ─── PayHere Credentials ──────────────────────────────────────────────────────
# Sandbox Merchant ID is always 1219668 for testing
# Live Merchant ID: found in Account page of live dashboard (payhere.lk)
PAYHERE_MERCHANT_ID=1219668

# App Secret from Settings → API Keys → your app
PAYHERE_MERCHANT_SECRET=your_app_secret_here

# App ID from Settings → API Keys
PAYHERE_APP_ID=your_app_id_here

# true = sandbox (testing), false = live (real money)
PAYHERE_SANDBOX=true

# ─── Your site URL ────────────────────────────────────────────────────────────
# Local: http://localhost:3000
# Deployed: https://your-project.vercel.app
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─── Health Check (any random string) ────────────────────────────────────────
CRON_SECRET=dof_health_2026
